// ============================================================================
// DSM OUTSOURCING - DATABASE SCHEMA (PostgreSQL/Supabase)
// ============================================================================
// This schema is designed for production use with Supabase/PostgreSQL.
// For local development, you can use SQLite by changing the provider.
//
// Setup:
// 1. Set DATABASE_URL in your .env file
// 2. Run: npx prisma db push
// 3. Run: npx prisma studio (to view data)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model Admin {
  id           String    @id @default(cuid())
  username     String    @unique @db.VarChar(50)
  password     String    @db.VarChar(255) // bcrypt hashed
  name         String    @db.VarChar(100)
  email        String?   @db.VarChar(255)
  image        String?   @db.VarChar(500)
  phone        String?   @db.VarChar(50)
  bio          String?   @db.Text
  role         Role      @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([username])
  @@index([email])
  @@map("admins")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// ============================================================================
// COURSES & CATEGORIES
// ============================================================================

model CourseCategory {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  icon        String?   @db.VarChar(50)
  color       String?   @db.VarChar(20)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  courses     Course[]

  @@index([slug])
  @@map("course_categories")
}

model Course {
  id              String          @id @default(cuid())
  name            String          @db.VarChar(200)
  slug            String          @unique @db.VarChar(200)
  description     String          @db.Text
  longDescription String?         @db.Text
  price           Float           @default(0)
  duration        String          @db.VarChar(50)
  level           CourseLevel     @default(BEGINNER)
  image           String?         @db.VarChar(500)
  icon            String?         @db.VarChar(50)
  features        String?         @db.Text // JSON array
  modules         String?         @db.Text // JSON array
  requirements    String?         @db.Text // JSON array
  isActive        Boolean         @default(true)
  order           Int             @default(0)
  categoryId      String?
  category        CourseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  enrollments     Enrollment[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

// ============================================================================
// STUDENTS & ENROLLMENTS
// ============================================================================

model Student {
  id          String       @id @default(cuid())
  name        String       @db.VarChar(100)
  email       String       @unique @db.VarChar(255)
  phone       String       @db.VarChar(50)
  address     String?      @db.Text
  dateOfBirth String?      @db.VarChar(20)
  education   String?      @db.VarChar(100)
  nid         String?      @db.VarChar(50) // National ID
  photo       String?      @db.VarChar(500)
  notes       String?      @db.Text
  status      StudentStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]

  @@index([email])
  @@index([status])
  @@map("students")
}

enum StudentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

model Enrollment {
  id            String        @id @default(cuid())
  studentId     String
  courseId      String
  transactionId String?       @db.VarChar(100)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?       @db.VarChar(50)
  amount        Float?
  status        EnrollmentStatus @default(ENROLLED)
  enrolledAt    DateTime      @default(now())
  completedAt   DateTime?
  notes         String?       @db.Text
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentId])
  @@index([courseId])
  @@index([paymentStatus])
  @@index([status])
  @@map("enrollments")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

// ============================================================================
// SUCCESS STORIES
// ============================================================================

model SuccessStory {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  course      String   @db.VarChar(200)
  company     String?  @db.VarChar(200)
  position    String?  @db.VarChar(100)
  image       String?  @db.VarChar(500)
  testimonial String   @db.Text
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("success_stories")
}

// ============================================================================
// MESSAGING & COMMUNICATION
// ============================================================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  subject   String?  @db.VarChar(200)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@map("contact_messages")
}

model ChatMessage {
  id           String   @id @default(cuid())
  content      String   @db.Text
  senderType   SenderType
  senderId     String   @db.VarChar(50)
  senderName   String   @db.VarChar(100)
  receiverType ReceiverType
  receiverId   String?  @db.VarChar(50)
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([senderType, senderId])
  @@index([receiverType, receiverId])
  @@index([isRead])
  @@map("chat_messages")
}

enum SenderType {
  ADMIN
  STUDENT
  GUEST
}

enum ReceiverType {
  ADMIN
  STUDENT
  BROADCAST
}

// ============================================================================
// SETTINGS & STATISTICS
// ============================================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Statistic {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     Int
  updatedAt DateTime @updatedAt

  @@map("statistics")
}
